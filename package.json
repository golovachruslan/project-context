{
  "name": "pctx",
  "version": "0.1.0",
  "description": "CLI tool for managing project-context cross-project dependencies",
  "license": "MIT",
  "type": "module",
  "bin": {
    "pc": "./bin/pc.mjs"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "build": "unbuild",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.2.0",
    "chalk": "^5.3.0",
    "citty": "^0.1.6",
    "cli-table3": "^0.6.5",
    "execa": "^9.5.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "unbuild": "^3.3.1"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "project-context",
    "dependencies",
    "cli",
    "monorepo"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/golovachruslan/project-context.git"
  }
}
